<Window Width="512" Height="512" x:Class="StartPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:StartPro"
        ResizeMode="CanMinimize" MouseDown="GoDragMove">
    <StackPanel>
        <ComboBox x:Name="clipTypeCombo" SelectionChanged="ChangeClipType">
            <ComboBoxItem Content="小" />
            <ComboBoxItem Content="中" />
            <ComboBoxItem Content="宽" />
            <ComboBoxItem Content="大" />
        </ComboBox>
        <local:AppClip x:Name="appClip" AppName="Notepad" AppPath="C:\Windows\System32\notepad.exe"
                AppIcon="Test.png" ClipRadius="32,32,32,32" ClipFontSize="22" Margin="10,10,10,10"
                ClipSize="Medium" />
    </StackPanel>
</Window>
