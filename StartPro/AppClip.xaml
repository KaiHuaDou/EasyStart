<UserControl x:Class="StartPro.AppClip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" MouseUp="Execute">
    <Border x:Name="border">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{Binding ClipColor}" />
                <Setter Property="CornerRadius" Value="{Binding ClipRadius}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{Binding ClipColor}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <DockPanel>
            <Label Margin="0,0,0,5" DockPanel.Dock="Bottom"
                   HorizontalAlignment="Center"
                   Content="{Binding AppName}"
                   FontSize="{Binding ClipFontSize}"
                   Foreground="White" />
            <Image Margin="15,10,15,5" Source="{Binding AppIcon}" />
        </DockPanel>
    </Border>
</UserControl>
